# ===========================================
# CHECKLIST CCO - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores
# NUNCA commit o arquivo .env com dados sensíveis

# -------------------------------------------
# Google Gemini (IA)
# -------------------------------------------
GEMINI_API_KEY=sua_chave_aqui

# -------------------------------------------
# Microsoft Azure AD (Autenticação)
# -------------------------------------------
VITE_AZURE_CLIENT_ID=seu_client_id_aqui
VITE_AZURE_TENANT_ID=seu_tenant_id_aqui
VITE_AZURE_SCOPES=User.Read,Sites.ReadWrite.All

# -------------------------------------------
# Microsoft Azure AD (Viewer - 2º App Registration)
# -------------------------------------------
VITE_AZURE_VIEWER_CLIENT_ID=seu_client_id_viewer_aqui
VITE_AZURE_VIEWER_TENANT_ID=seu_tenant_id_viewer_aqui
VITE_AZURE_VIEWER_SCOPES=User.Read,Sites.ReadWrite.All
# Opcional: se não preencher, usa https://login.microsoftonline.com/VITE_AZURE_VIEWER_TENANT_ID
VITE_AZURE_VIEWER_AUTHORITY=

# -------------------------------------------
# SharePoint Online
# -------------------------------------------
VITE_SHAREPOINT_SITE_PATH=seu_site_sharepoint_aqui
VITE_VIEWER_ACCESS_LIST_NAME=Usuário_filial

# -------------------------------------------
# Webhooks (n8n)
# -------------------------------------------
VITE_WEBHOOK_SAIDAS_URL=https://n8n.datastack.viagroup.com.br/webhook/seu_webhook_aqui
VITE_WEBHOOK_RESUMO_URL=https://n8n.datastack.viagroup.com.br/webhook/seu_webhook_aqui

# -------------------------------------------
# Servidor de Desenvolvimento
# -------------------------------------------
VITE_SERVER_PORT=3000

# -------------------------------------------
# Segurança - Limitação de Login
# -------------------------------------------
# Máximo de tentativas de login falhas antes do bloqueio temporário
LIMITAR_RETRY_LOGIN=5

# Tempo de bloqueio em minutos após atingir o limite de tentativas
LOGIN_LOCKOUT_MINUTES=15

# -------------------------------------------
# Cloudflare Turnstile (Proteção Anti-Bot)
# -------------------------------------------
# SITE_KEY: chave pública do widget (frontend)
# SECRET_KEY: chave secreta para validação server-side (configurar no Vercel Dashboard)
SITE_KEY=sua_turnstile_site_key_aqui
